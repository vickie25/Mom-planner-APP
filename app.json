{
  "expo": {
    "name": "Mom Planner",
    "slug": "mom-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1EB"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.momplanner.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1EB"
      },
      "package": "com.momplanner.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "momplanner",
    "plugins": [
      "expo-router"
    ]
  }
}